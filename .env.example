# ============================================================
# TokenBase 环境变量（全部可选）
# 不填任何一项也能上线 —— 网站会进入「演示模式」：
#   客户能注册、领 $5、调模型（返回示例结果）、用模拟支付充值。
# 下面各项按需填写，填了哪一项，那一项就从「演示」变成「真的」。
# 在部署平台（Railway / Render）的 Variables 面板里，每行填一个。
# ============================================================

# ---- 服务端口（部署平台会自动注入，本地默认 3000，一般不用改）----
# PORT=3000

# ---- 数据库（必填！用 Supabase / Neon 的 Postgres 连接串）----
# Render 免费版文件系统是临时的，每次部署会清空本地数据，
# 所以用户/余额必须存在外部数据库里。没填则用本地 JSON（仅本地开发用）。
# DATABASE_URL=postgresql://postgres:密码@db.xxxx.supabase.co:5432/postgres

# ---- 注册赠送额度（美元），默认 5 ----
# FREE_CREDIT_ON_SIGNUP=5

# ============================================================
# 国内大模型上游 Key（至少填一个，对应模型才会返回真实结果）
# 去各厂商官网注册 → 开通 API → 复制 Key 粘贴到这里
# ============================================================
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
QIANFAN_API_KEY=
MINIMAX_API_KEY=
STEPFUN_API_KEY=
ARK_API_KEY=

# ============================================================
# 支付方式（决定「Buy credits」走真实收款还是模拟）
#   sandbox        = 模拟支付（默认，无需商户号，先体验流程）
#   paddle         = Paddle（推荐，自动算各国税）
#   lemonsqueezy   = LemonSqueezy
# ============================================================
PAYMENT_PROVIDER=sandbox

# ---- Paddle ----
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=          # Paddle.js 前端叠加层结账用（跟 API Key 不同）
PADDLE_ENV=sandbox
PADDLE_PRICE_STARTER=
PADDLE_PRICE_PRO=
PADDLE_PRICE_SCALE=

# ---- LemonSqueezy ----
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LS_STORE_ID=
LS_VAR_STARTER=
LS_VAR_PRO=
LS_VAR_SCALE=
LS_VAR_BUSINESS=
